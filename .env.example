# Telegram (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=tgtrading
# Comma-separated group chat IDs (negative numbers for groups)
TELEGRAM_GROUP_IDS=-

# Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite
# Grok AI
XAI_API_KEY=xai-
XAI_MODEL=grok-4.3

# cTrader Open API (https://openapi.ctrader.com)
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=
CTRADER_HOST_TYPE=live
CTRADER_REDIRECT_URI=http://localhost:8080

# Trading defaults
DEFAULT_VOLUME=0.01
MIN_VOLUME=0.01
MAX_VOLUME=0.1
TRADING_ENABLED=true
AGGRESSIVE_MODE=true

ALLOWED_SYMBOLS=XAUUSDm,BTCUSDm
DEFAULT_SYMBOL=XAUUSDm

MAX_ORDER_COUNT=20
MAX_ORDER_PER_GROUP=5
CONTEXT_MESSAGE_COUNT=5
