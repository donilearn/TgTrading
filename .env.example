# Telegram (https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=tgtrading
# Comma-separated group chat IDs (negative numbers for groups)
TELEGRAM_GROUP_IDS=-

# Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# MetaAPI Cloud — default: python main.py (https://app.metaapi.cloud)
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=

# MetaTrader 5 local — faqat --win (Windows, terminal ochiq)
# Yo'l: forward slash yoki qo'sh backslash (\\terminal64) — aks holda \t tab bo'ladi
# MT5_PATH=C:/Program Files/XM Global MT5/terminal64.exe
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TIMEOUT=60000

# Trading defaults
DEFAULT_VOLUME=0.01
MIN_VOLUME=0.01
MAX_VOLUME=0.1
TRADING_ENABLED=true
AGGRESSIVE_MODE=true

ALLOWED_SYMBOLS=XAUUSDm,BTCUSDm
DEFAULT_SYMBOL=XAUUSDm

MAX_ORDER_COUNT=20
# Bitta signal uchun max entry (6+ TP uchun kamida 6 qo'ying)
MAX_ORDER_PER_GROUP=8
CONTEXT_MESSAGE_COUNT=5
# Pending limit/stop order expiration in minutes (0 = GTC when AI returns null)
ORDERS_EXPIRATION=20
# Signalda SL/TP yo'q bo'lsa entry narxidan pip masofasi (0 = o'chirilgan)
DEFAULT_SL_PIPS=5000
DEFAULT_TP_PIPS=10000
# Har Telegram xabarida ochiq pozitsiya profit >= N pip bo'lsa SL=openPrice (0=o'chirilgan)
AUTO_BE_PIPS=100
